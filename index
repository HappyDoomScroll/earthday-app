function GameScreen({level,onLevelComplete}) {
  const lData = LEVELS[level-1];
  const items = useMemo(() => {
    const pool = lData.itemPool.map(id => ALL_ITEMS.find(x => x.id === id)).filter(Boolean);
    return [...pool].sort(() => Math.random() - 0.5).slice(0, lData.itemCount);
  }, [level]);

  const [idx, setIdx] = useState(0);
  const [timeLeft, setTimeLeft] = useState(lData.timePerItem);
  const [score, setScore] = useState(0);
  const [phase, setPhase] = useState('playing');
  const [lastCorrect, setLastCorrect] = useState(null);
  const [sunMood, setSunMood] = useState('happy');
  const [hoveredBin, setHoveredBin] = useState(null);
  const [showConfetti, setShowConfetti] = useState(false);
  const [floatText, setFloatText] = useState(null);
  const [flashBin, setFlashBin] = useState(null); 
  const [itemKey, setItemKey] = useState(0);
  const [dragPos, setDragPos] = useState(null); 

  const dragState = useRef({dragging:false, x:0, y:0});
  const binRefs = useRef({});
  const timerRef = useRef(null);
  const currentItem = items[idx];

  useEffect(()=>{
    if(phase!=='playing') return; 
    setTimeLeft(lData.timePerItem);
    timerRef.current = setInterval(()=>{
      setTimeLeft(t=>{
        if(t<=0.1){ clearInterval(timerRef.current); handleAnswer(null); return 0; }
        if(t<=3) setSunMood('worried');
        return parseFloat((t-0.1).toFixed(1));
      });
    },100);
    return ()=>clearInterval(timerRef.current);
  },[idx, phase]);

  const handleAnswer = useCallback((chosenBin)=>{
    if(phase!=='playing') return;
    clearInterval(timerRef.current);
    const correct = chosenBin === currentItem.bin;
    setLastCorrect(correct);
    if(chosenBin) setFlashBin({bin:chosenBin,ok:correct});
    setTimeout(()=>setFlashBin(null),500);
    if(correct){
      setScore(s=>s+1);
      setSunMood('veryHappy');
      setShowConfetti(true);
      setFloatText('+1');
      setTimeout(()=>setShowConfetti(false),1300);
      setTimeout(()=>setFloatText(null),950);
    } else {
      setSunMood('sad');
    }
    setTimeout(()=>setPhase('fact'),400);
  },[phase, currentItem]);

  const handleNext = ()=>{
    if(idx+1 >= items.length){ onLevelComplete(score+(lastCorrect?1:0),items.length); return; }
    setPhase('playing');
    setSunMood('happy');
    setHoveredBin(null);
    setDragPos(null);
    dragState.current.dragging=false;
    setItemKey(k=>k+1);
    setIdx(i=>i+1);
  };

  const onPointerDown = (e)=>{
    if(phase!=='playing') return;
    e.currentTarget.setPointerCapture(e.pointerId);
    dragState.current = {dragging:true, x:e.clientX, y:e.clientY};
    setDragPos({x:e.clientX, y:e.clientY});
    setSunMood('neutral');
  };

  const onPointerMove = (e)=>{
    if(!dragState.current.dragging) return;
    setDragPos({x:e.clientX, y:e.clientY});
    let found = null;
    for(const [binId,ref] of Object.entries(binRefs.current)){
      if(!ref) continue;
      const r = ref.getBoundingClientRect();
      if(e.clientX>=r.left&&e.clientX<=r.right&&e.clientY>=r.top&&e.clientY<=r.bottom){
        found=binId; break;
      }
    }
    setHoveredBin(found);
  };

  const onPointerUp = (e)=>{
    if(!dragState.current.dragging) return;
    dragState.current.dragging=false;
    let target = hoveredBin;
    setDragPos(null);
    setHoveredBin(null);
    if(target) handleAnswer(target);
    else setSunMood('happy');
  };

  if(!currentItem) return null;

  return (
    <div style={{height:'100%',display:'flex',flexDirection:'column',position:'relative',overflow:'hidden',userSelect:'none'}}>
      <BackgroundClouds />
      {showConfetti&&<Confetti/>}
      <div style={{padding:'16px 18px 4px',display:'flex',flexDirection:'column',gap:14, position:'relative', zIndex:10}}>
        <div style={{display:'flex', justifyContent:'space-between', alignItems:'center'}}>
          <div style={{background:CARD_BG, border:`3px solid ${BORDER_COLOR}`,borderRadius:99,padding:'6px 12px', display:'flex', alignItems:'center', gap: 6,fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:14,color:TEXT_DARK,boxShadow:`0 3px 0 ${BORDER_COLOR}`}}>
            L{level} <BinIcon type={lData.icon} size={16} color={lData.color}/>
          </div>
          <div style={{background:'#E0F2FE', border:`3px solid ${BORDER_COLOR}`,borderRadius:99,padding:'6px 12px', display:'flex', alignItems:'center', gap: 6,fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:14,color:TEXT_DARK,boxShadow:`0 3px 0 ${BORDER_COLOR}`}}>
            <UIcon name="box" size={16} color="#38BDF8"/> {idx + 1} / {items.length}
          </div>
          <div style={{background:'#FEF08A', border:`3px solid ${BORDER_COLOR}`,borderRadius:99,padding:'6px 12px', display:'flex', alignItems:'center', gap: 6,fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:14,color:TEXT_DARK,boxShadow:`0 3px 0 ${BORDER_COLOR}`}}>
            <UIcon name="star" size={16} color="#F59E0B"/> {score}
          </div>
        </div>
        <TimerBar timeLeft={timeLeft} totalTime={lData.timePerItem}/>
      </div>

      <div style={{flex:1,display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',gap:10,padding:'0 18px',position:'relative', zIndex:10}}>
        <div style={{animation:sunMood==='veryHappy'?'correctPop 0.5s ease':sunMood==='sad'?'wrongShake 0.5s ease':'bounce 2.4s infinite'}}>
          <SunFace mood={sunMood} size={Math.min(96,window.innerWidth*0.22)}/>
        </div>
        <p style={{fontFamily:'Fredoka,sans-serif',fontSize:15,fontWeight:700,color:'rgba(0,0,0,0.6)',textAlign:'center'}}>
          {dragPos ? 'Drop it in the right bin! 🎯' : 'Grab and drag to a bin below ↓'}
        </p>
        <div onPointerDown={onPointerDown} onPointerMove={onPointerMove} onPointerUp={onPointerUp} style={{background:CARD_BG, border:`4px solid ${BORDER_COLOR}`, borderRadius:32,padding:'24px',textAlign:'center',cursor:'grab',animation:dragPos?'none':'itemDrop 0.45s cubic-bezier(0.175,0.885,0.32,1.275)',opacity:dragPos?0.3:1,boxShadow: `0 8px 0 ${BORDER_COLOR}`,width: 200, height: 210, display:'flex', flexDirection:'column', justifyContent:'center', alignItems:'center'}}>
          <div style={{height:110, display:'flex', alignItems:'center', justifyContent:'center', marginBottom:12}}><HandDrawnIcon type={currentItem.type} size={90} /></div>
          <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:'clamp(18px,4.5vw,22px)',color:TEXT_DARK, lineHeight:1.2}}>{currentItem.name}</div>
        </div>
        {floatText&&(
          <div style={{position:'absolute',top:'38%',left:'50%',fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:28,color:'#FBBF24', textShadow:`-2px -2px 0 #1C1C1C, 2px -2px 0 #1C1C1C, -2px 2px 0 #1C1C1C, 2px 2px 0 #1C1C1C`,pointerEvents:'none',animation:'floatUp 0.9s ease forwards',zIndex:20,display: 'flex', alignItems: 'center', gap: 6}}>+{floatText} <UIcon name="star" size={28} color="#FBBF24"/></div>
        )}
      </div>

      <div style={{padding:'8px 14px 24px',display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:8, position:'relative', zIndex:10}}>
        {lData.bins.map(binId=>{
          const b=BINS[binId];
          const hovered=hoveredBin===binId;
          const flash=flashBin?.bin===binId;
          return (
            <div key={binId} ref={el=>binRefs.current[binId]=el} style={{borderRadius:20,padding:'12px 4px',display:'flex',flexDirection:'column',alignItems:'center',gap:6,background: flash? (flashBin.ok?b.color:'#EF4444') : (hovered?b.color:CARD_BG),border:`4px solid ${BORDER_COLOR}`,transition:'all 0.15s cubic-bezier(0.175,0.885,0.32,1.275)',transform:hovered?'scale(1.08) translateY(-4px)':'scale(1)',boxShadow: hovered ? `0 8px 0 ${BORDER_COLOR}` : `0 4px 0 ${BORDER_COLOR}`}}>
              <BinIcon type={binId} size={36} color={hovered || flash ? "white" : b.color}/>
              <span style={{fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:12,color:TEXT_DARK,textAlign:'center',lineHeight:1.1}}>{b.label}</span>
            </div>
          );
        })}
      </div>

      {dragPos && (
        <div style={{position:'fixed', left:dragPos.x-100, top:dragPos.y-105,width:200, pointerEvents:'none', zIndex:999,textAlign:'center',animation:'dragLift 0.15s ease forwards'}}>
          <div style={{background:CARD_BG,border:`4px solid ${BORDER_COLOR}`,borderRadius:32,padding:'24px',boxShadow: `0 16px 24px rgba(0,0,0,0.25), 0 8px 0 ${BORDER_COLOR}`,display:'flex', flexDirection:'column', justifyContent:'center', alignItems:'center', height: 210}}>
            <div style={{height:110, display:'flex', alignItems:'center', justifyContent:'center', marginBottom:12}}><HandDrawnIcon type={currentItem.type} size={90} /></div>
            <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:'clamp(18px,4.5vw,22px)',color:TEXT_DARK, lineHeight:1.2}}>{currentItem.name}</div>
          </div>
        </div>
      )}
      {phase==='fact'&&<FactCard item={currentItem} correct={lastCorrect} onNext={handleNext}/>}
    </div>
  );
}

