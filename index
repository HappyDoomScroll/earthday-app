// ─── UI & BIN ICONS ─────────────────────────────────────────────────────────
function BinIcon({ type, size=40, color="white" }) {
  const stroke = BORDER_COLOR;
  const isWhite = color === 'white';
  const symbolFill = isWhite ? stroke : 'white';

  const binBase = (
    <g stroke={stroke} strokeWidth="6" strokeLinejoin="round" strokeLinecap="round">
       <path d="M 25 30 L 75 30 L 65 90 L 35 90 Z" fill={color} />
       <rect x="15" y="15" width="70" height="15" rx="4" fill={color} />
    </g>
  );

  let symbol = null;
  if (type === 'recycle') {
     symbol = (
       <g stroke={stroke} strokeWidth="5" strokeLinejoin="round" fill={symbolFill} transform="translate(50, 60) scale(0.35) translate(-50, -50)">
         {[0, 120, 240].map(deg => (
           <g key={deg} transform={`rotate(${deg} 50 55)`}>
             <path d="M 40 20 Q 65 20 75 40 L 62 45 Q 55 32 40 32 Z" />
             <polygon points="70,32 90,45 65,55" />
           </g>
         ))}
       </g>
     );
  } else if (type === 'compost') {
     symbol = (
       <g stroke={stroke} strokeWidth="6" strokeLinejoin="round" strokeLinecap="round" transform="translate(50, 60) scale(0.35) translate(-50, -50)">
         <path d="M 50 85 L 50 40" fill="none" />
