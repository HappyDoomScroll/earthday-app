               <div style={{textAlign:'left', flex: 1}}>
                 <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:20,color:TEXT_DARK, lineHeight:1.1, marginBottom: 6}}>{b.label}</div>
                 <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:700,fontSize:13,color:TEXT_DARK, marginBottom: 8, lineHeight: 1.3}}>
                   {binId === 'recycle' && "The arrows mean it goes round & round to become something brand new!"}
                   {binId === 'compost' && "The plant means it goes back to the earth to help new things grow!"}
                   {binId === 'trash'   && "The trash can means it goes to a landfill forever. Try to use this the least!"}
                   {binId === 'special' && "The lightning bolt means it needs extra careful, special sorting!"}
                 </div>
                 <div style={{display:'flex', gap: 8}}>
                   {binId === 'recycle' && <><HandDrawnIcon type="bottle" size={24}/><HandDrawnIcon type="can" size={24}/><HandDrawnIcon type="box" size={24}/></>}
                   {binId === 'compost' && <><HandDrawnIcon type="apple" size={24}/><HandDrawnIcon type="carrot" size={24}/><HandDrawnIcon type="banana" size={24}/></>}
                   {binId === 'trash'   && <><HandDrawnIcon type="wrapper" size={24}/><HandDrawnIcon type="cup" size={24}/><HandDrawnIcon type="trash" size={24}/></>}
                   {binId === 'special' && <><HandDrawnIcon type="battery" size={24}/><HandDrawnIcon type="tech" size={24}/><HandDrawnIcon type="controller" size={24}/></>}
                 </div>
               </div>
            </div>
          );
        })}
      </div>
      <button onClick={onNext} className="btn-cartoony" style={{background:'#4ADE80',color:TEXT_DARK, borderBottomWidth:'8px', maxWidth: 420,padding:'16px 44px',fontSize:22,width:'100%'}}>I'm Ready! →</button>
    </Shell>
  );
}

function LevelIntro({level,onGo}) {
  const l=LEVELS[level-1];
  return (
    <Shell>
      <div style={{marginBottom:16,animation:'levelBadge 0.6s cubic-bezier(0.175,0.885,0.32,1.275)'}}>
        <BinIcon type={l.icon} size={84} color={l.color}/>
      </div>
      <div style={{display:'inline-block',background:l.color,border:`3px solid ${BORDER_COLOR}`,borderRadius:99,padding:'6px 20px',marginBottom:16,fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:15,color:TEXT_DARK,boxShadow:`0 4px 0 ${BORDER_COLOR}`}}>Level {l.id} of 3</div>
      <h2 style={{fontFamily:'Fredoka,sans-serif',fontWeight:900,fontSize:'clamp(32px,9vw,48px)',color:'#FFFFFF',lineHeight:1.1,marginBottom:10,textShadow:`-2px -2px 0 ${BORDER_COLOR}, 2px -2px 0 ${BORDER_COLOR}, -2px 2px 0 ${BORDER_COLOR}, 2px 2px 0 ${BORDER_COLOR}, 0 4px 0 ${BORDER_COLOR}`}}>{l.name}</h2>
      <p style={{fontFamily:'Fredoka,sans-serif',fontWeight:700,fontSize:18,color:TEXT_DARK,marginBottom:24, background:'rgba(255,255,255,0.9)', padding:'8px 16px', borderRadius:16, border:`3px solid ${BORDER_COLOR}`}}>{l.subtitle}</p>
      <div style={{background:CARD_BG,border:`4px solid ${BORDER_COLOR}`,boxShadow:`0 6px 0 ${BORDER_COLOR}`,borderRadius:28,padding:'20px',marginBottom:24, width: '100%'}}>
        <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:800,fontSize:14,color:'#4B5563',marginBottom:16,letterSpacing:'0.05em'}}>YOUR BINS:</div>
        <div style={{display:'flex',gap:12,justifyContent:'center',flexWrap:'wrap'}}>
          {l.bins.map(b=>(
            <div key={b} style={{display:'flex',flexDirection:'column',alignItems:'center',gap:6}}>
              <div style={{width:56,height:56,borderRadius:16,background:BINS[b].color,border:`3px solid ${BORDER_COLOR}`, boxShadow:`0 4px 0 ${BORDER_COLOR}`,display:'flex',alignItems:'center',justifyContent:'center'}}><BinIcon type={b} size={32} color="white"/></div>
              <span style={{fontFamily:'Fredoka,sans-serif',fontSize:13,color:TEXT_DARK,fontWeight:800}}>{BINS[b].label}</span>
            </div>
          ))}
        </div>
        <div style={{marginTop: 18, paddingTop: 14, borderTop: `2px dashed ${BORDER_COLOR}44`, fontFamily:'Fredoka,sans-serif', fontSize: 14, color: '#4B5563', fontWeight: 600}}>💡 <strong style={{color: TEXT_DARK}}>Pro Tip:</strong> Try to <span style={{color: '#DC2626', fontWeight: 800}}>reduce trash</span> so the red bin stays empty!</div>
      </div>
      <div style={{display:'flex',gap:16,justifyContent:'center',marginBottom:28,fontFamily:'Fredoka,sans-serif',fontSize:15,color:TEXT_DARK,fontWeight:700,background:'rgba(255,255,255,0.9)', padding:'10px 20px', borderRadius:99, border:`3px dashed ${BORDER_COLOR}`, alignItems:'center'}}>
        <span style={{display:'flex', alignItems:'center', gap: 6}}><UIcon name="clock" size={20} color={BORDER_COLOR}/> {l.timePerItem}s</span>
        <span>·</span>
        <span style={{display:'flex', alignItems:'center', gap: 6}}><UIcon name="box" size={20} color={BORDER_COLOR}/> {l.itemCount} items</span>
      </div>
      <button onClick={onGo} className="btn-cartoony" style={{background:l.color,color:TEXT_DARK, borderBottomWidth:'8px',padding:'16px 44px',fontSize:22,width:'100%'}}>Start Level {l.id}! →</button>
    </Shell>
  );
}

function ResultsScreen({score,total,level,onNext,onReplay,isLastLevel}) {
  const pct=Math.round((score/total)*100);
  const msg = pct >= 90 ? 'Perfect! You\'re amazing!' : pct >= 70 ? 'Great job, keep it up!' : 'Good try! Practice makes perfect!';
  const accent = isLastLevel ? '#FBBF24' : '#4ADE80';
  return (
    <Shell>
      {pct >= 90 && <Confetti/>}
      <div style={{marginBottom:18,animation:pct >= 90?'bounce 1s infinite':'none'}}><SunFace mood={pct >= 70 ? 'veryHappy' : 'sad'} size={130}/></div>
      <h2 style={{fontFamily:'Fredoka,sans-serif',fontWeight:900,fontSize:'clamp(28px,8vw,42px)',color:'#FFFFFF',marginBottom:10,textShadow:`-2px -2px 0 ${BORDER_COLOR}, 2px -2px 0 ${BORDER_COLOR}, -2px 2px 0 ${BORDER_COLOR}, 2px 2px 0 ${BORDER_COLOR}, 0 4px 0 ${BORDER_COLOR}`}}>Level {level} Complete!</h2>
      <p style={{fontFamily:'Fredoka,sans-serif',fontWeight:700,fontSize:18,color:TEXT_DARK,marginBottom:24,background:'rgba(255,255,255,0.8)', padding:'8px 16px', borderRadius:16, border:`2px solid ${BORDER_COLOR}`}}>{msg}</p>
      <div style={{background:CARD_BG,border:`4px solid ${BORDER_COLOR}`,boxShadow:`0 8px 0 ${BORDER_COLOR}`,borderRadius:32,padding:'24px',marginBottom:28, width: '100%'}}>
        <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:900,fontSize:'clamp(48px,14vw,72px)',color:pct >= 90?'#FBBF24':pct >= 70?'#4ADE80':'#60A5FA', lineHeight:1}}>{score}/{total}</div>
        <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:700,fontSize:16,color:'#4B5563', marginTop:8}}>correct · {pct}%</div>
        <div style={{marginTop:12, display:'flex', justifyContent:'center', gap: 4}}>
           <UIcon name="star" size={32} color={pct>=33?'#FBBF24':'#E5E7EB'}/><UIcon name="star" size={32} color={pct>=66?'#FBBF24':'#E5E7EB'}/><UIcon name="star" size={32} color={pct>=90?'#FBBF24':'#E5E7EB'}/>
        </div>
      </div>
      <div style={{display:'flex',gap:14, width:'100%'}}>
        <button onClick={onReplay} className="btn-cartoony" style={{flex:1,background:'#F3F4F6',color:TEXT_DARK, borderBottomWidth:'6px',padding:'14px 0',fontSize:18}}>↩ Replay</button>
        <button onClick={onNext} className="btn-cartoony" style={{flex:2,background:accent,color:TEXT_DARK, borderBottomWidth:'6px',padding:'14px 0',fontSize:20}}>{isLastLevel?'Finish!':'Next Level →'}</button>
      </div>
    </Shell>
  );
}

function FinalScreen({totalScore,totalItems,onPlayAgain}) {
  const pct=Math.round((totalScore/totalItems)*100);
  return (
    <Shell>
      <Confetti/>
      <div style={{marginBottom:16,animation:'bounce 1.5s infinite'}}><UIcon name="trophy" size={96} color="#FBBF24" /></div>
      <h2 style={{fontFamily:'Fredoka,sans-serif',fontWeight:900,fontSize:'clamp(32px,9vw,48px)',color:'#FFFFFF',marginBottom:12,textShadow:`-2px -2px 0 ${BORDER_COLOR}, 2px -2px 0 ${BORDER_COLOR}, -2px 2px 0 ${BORDER_COLOR}, 2px 2px 0 ${BORDER_COLOR}, 0 4px 0 ${BORDER_COLOR}`}}>Recycling Hero!</h2>
      <p style={{fontFamily:'Fredoka,sans-serif',fontWeight:700,fontSize:18,color:TEXT_DARK,marginBottom:28,lineHeight:1.5,background:'rgba(255,255,255,0.8)', padding:'12px 20px', borderRadius:20, border:`3px solid ${BORDER_COLOR}`}}>The Sun thanks you for sorting {totalScore} items correctly!</p>
      <div style={{background:CARD_BG,border:`4px solid ${BORDER_COLOR}`,boxShadow:`0 8px 0 ${BORDER_COLOR}`,borderRadius:32,padding:'24px',marginBottom:28, width: '100%'}}>
        <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:900,fontSize:72,color:'#FBBF24', lineHeight:1}}>{pct}%</div>
        <div style={{fontFamily:'Fredoka,sans-serif',fontWeight:700,fontSize:16,color:'#4B5563', marginTop:8}}>overall accuracy</div>
        <div style={{marginTop:12, display:'flex', justifyContent:'center', gap:6}}><UIcon name="star" size={36} color="#FBBF24"/><UIcon name="star" size={36} color="#FBBF24"/><UIcon name="star" size={36} color="#FBBF24"/></div>
      </div>
      <button onClick={onPlayAgain} className="btn-cartoony" style={{background:'#4ADE80',color:TEXT_DARK, borderBottomWidth:'8px',padding:'18px 48px',fontSize:22,width:'100%'}}>Play Again!</button>
    </Shell>
  );
}

function App() {
  const [screen, setScreen]= useState(()=>localStorage.getItem('sio_screen')||'welcome');
  const [level,  setLevel] = useState(()=>parseInt(localStorage.getItem('sio_level')||'1'));
  const [scores, setScores]= useState(()=>JSON.parse(localStorage.getItem('sio_scores')||'{}'));

  const go=(s,lv)=>{
    if(lv!==undefined){ setLevel(lv); localStorage.setItem('sio_level',lv); }
    setScreen(s); localStorage.setItem('sio_screen',s);
  };

  const handleLevelComplete=(score,total)=>{
    const ns={...scores,[level]:{score,total}};
    setScores(ns); localStorage.setItem('sio_scores',JSON.stringify(ns));
    go('results');
  };

  const totalScore=Object.values(scores).reduce((a,b)=>a+b.score,0);
  const totalItems=Object.values(scores).reduce((a,b)=>a+b.total,0);

  return (
    <div style={{width:'100%',height:'100%',fontFamily:'Fredoka,sans-serif'}}>
      {screen==='welcome'   && <WelcomeScreen onStart={()=>go('levelintro',1)} onTutorial={()=>go('review')}/>}
      {screen==='review'    && <ReviewScreen onNext={()=>go('levelintro',1)}/>}
      {screen==='levelintro'&& <LevelIntro level={level} onGo={()=>go('game')}/>}
      {screen==='game'      && <GameScreen key={`game-${level}`} level={level} onLevelComplete={handleLevelComplete}/>}
      {screen==='results'   && <ResultsScreen score={scores[level]?.score||0} total={scores[level]?.total||1} level={level} isLastLevel={level===LEVELS.length} onReplay={()=>go('game')} onNext={()=>{ if(level<LEVELS.length) go('levelintro',level+1); else go('final'); }} />}
      {screen==='final'     && <FinalScreen totalScore={totalScore} totalItems={totalItems} onPlayAgain={()=>{ setScores({}); localStorage.removeItem('sio_scores'); go('welcome',1); }} />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
