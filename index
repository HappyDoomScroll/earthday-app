     symbol = (
       <g stroke={stroke} strokeWidth="6" strokeLinecap="round">
         <line x1="42" y1="45" x2="44" y2="75" />
         <line x1="50" y1="45" x2="50" y2="75" />
         <line x1="58" y1="45" x2="56" y2="75" />
         <path d="M 40 15 L 40 5 L 60 5 L 60 15" fill="none" />
       </g>
     );
